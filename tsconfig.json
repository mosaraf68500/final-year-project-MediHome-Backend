{
  "compilerOptions": {
   "module": "ESNext",                               
    "rootDir": "./src",
     "moduleResolution": "bundler",
    "outDir": "./dist",  
    "strict": true,
    "target": "ES2023",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["node_modules","dist"]
}



